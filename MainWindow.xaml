<Window x:Class="WpfEtwDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ETW Demo - Live / From ETL" Height="520" Width="800">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 模式選擇 -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8" VerticalAlignment="Center">
            <TextBlock Text="Mode:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="comboMode" Width="140" SelectedIndex="0">
                <ComboBoxItem Content="Live"/>
                <ComboBoxItem Content="From ETL"/>
            </ComboBox>

            <!-- Live 控制 -->
            <Button x:Name="btnStartLive" Content="Start Live" Width="100" Margin="12,0,4,0" Click="BtnStartLive_Click"/>
            <Button x:Name="btnStopLive" Content="Stop Live" Width="100" Margin="4,0,4,0" Click="BtnStopLive_Click" IsEnabled="False"/>

            <!-- ETL 控制 -->
            <Button x:Name="btnOpenEtl" Content="Open ETL" Width="100" Margin="12,0,4,0" Click="BtnOpenEtl_Click"/>
            <Button x:Name="btnStopEtl" Content="Stop ETL" Width="100" Margin="4,0,4,0" Click="BtnStopEtl_Click" IsEnabled="False"/>

            <TextBlock x:Name="txtStatus" VerticalAlignment="Center" Margin="12,0,0,0" Text="Ready"/>
        </StackPanel>

        <!-- 額外說明 -->
        <TextBlock Grid.Row="1" Text="注意：Live 模式需以管理員執行；請勿同時啟動 Live 與 ETL 讀取。" Foreground="Gray" FontSize="12" Margin="0,0,0,8"/>

        <!-- 事件顯示 -->
        <ListBox x:Name="listBoxEvents" Grid.Row="2"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling"/>
    </Grid>
</Window>
